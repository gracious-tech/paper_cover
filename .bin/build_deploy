#!/usr/bin/env bash
# Netlify build script — builds all dependencies then the widget
# Output: widget/dist/
set -euo pipefail

BIN="$(dirname "$0")"

echo "📦 Installing root dependencies..."
npm ci --omit=dev

echo "🔨 Building generator module..."
"$BIN/build_generator"

echo "🔨 Building generator-web module..."
"$BIN/build_generator-web"

echo "🔨 Building 3d module..."
"$BIN/build_3d"

echo "🔨 Building widget..."
"$BIN/build_widget"

echo "✅ Build complete! Output: widget/dist/"
