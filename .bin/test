#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Build generator and generator-node
cd "$ROOT/generator" && npm run build --silent
cd "$ROOT/generator-node" && npm run build --silent

# Shared schema used by all test cases
SCHEMA='{
    text: {
        title_pre: "The",
        title: "Art of Code",
        subtitle: "A journey through software craft",
        author: "Alice Chen",
        isbn: "978-3-16-148410-0",
        back_blurb: `*The Art of Code* is a deep dive into the timeless \
principles behind great software.

Whether you are a seasoned engineer or just starting out, this book will \
challenge the way you think about your craft.`,
    },
    colors: {
        front_background: "#1a1a2e",
        front_title:      "#e8e8f0",
        front_title_pre:  "#7f8cf7",
        front_subtitle:   "#aaaacc",
        front_author:     "#ccccdd",
        back_background:  "#16213e",
        back_blurb:       "#ddddee",
        spine_background: "#7f8cf7",
        spine_title:      "#1a1a2e",
        spine_author:     "#1a1a2e",
        accent:           "#7f8cf7",
    },
    size: {
        trim_width:  152,
        trim_height: 229,
        trim_unit:   "mm",
        page_count:  300,
    },
    images: {},
    theme: {name: "minimal", font: "serif"},
    printer: {name: "kdp", paper_type: "white"},
}'

# Run test generation — PDF, SVG, and PNG (with splitting)
node --input-type=module <<EOF
import {generate} from '$ROOT/generator-node/dist/index.js'

const schema = $SCHEMA

// PDF (default format, no splitting)
await generate({
    schema,
    input_path: '$ROOT',
    output_path: '$ROOT/test_cover.pdf',
})
console.log('Generated: test_cover.pdf')

// SVG with splitting
await generate({
    schema,
    input_path: '$ROOT',
    output_path: '$ROOT/test_cover.svg',
    format: 'svg',
    split: true,
})
console.log('Generated: test_cover.svg + split panels')

// PNG with splitting at 150 PPI
await generate({
    schema,
    input_path: '$ROOT',
    output_path: '$ROOT/test_cover.png',
    format: 'png',
    ppi: 150,
    split: true,
})
console.log('Generated: test_cover.png + split panels')
EOF
